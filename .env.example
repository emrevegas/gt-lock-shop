# Discord
DISCORD_TOKEN=
# Sunucu ID — slash komutların anında görünmesi için (Discord'da sunucuya sağ tık → Sunucu Kimliğini Kopyala)
GUILD_ID=
ADMIN_ROLE_IDS=123456789,987654321

# Luci: dosya kuyruğu (varsayılan, önerilen)
# data/luci/pending/, processing/, results/
# bot_balance.json — withdraw_worker.lua envanteri yazar (/bot_balance okur)
# BOT_HOME_WORLD — scripts/withdraw_worker.lua içinde ayarla (sipariş sonrası dönüş)

# Eski HTTP API (isteğe bağlı: ENABLE_HTTP_API=true)
ENABLE_HTTP_API=false
API_HOST=127.0.0.1
API_PORT=8765
LUCI_API_KEY=change-me-to-a-long-random-secret

# Crypto deposits (BIP39 mnemonic — NEVER commit real mnemonic)
CRYPTO_MNEMONIC=
BLOCKCYPHER_TOKEN=
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# Shop defaults (admin can override in Discord)
DEFAULT_PRICE_WL=1.0
DEFAULT_PRICE_DL=100.0
DEFAULT_PRICE_BGL=10000.0
MIN_DEPOSIT_USD=1.0

# Growtopia withdraw worlds (legacy — artık kullanıcı dünya adı girer)
WITHDRAW_WORLDS=
